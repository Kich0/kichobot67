# Server port
PORT=5000

# MongoDB connection string
DB_URI=mongodb://localhost:27017/ksu-helper

# JWT Secrets for authentication
JWT_ACCESS_SECRET=your_access_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here

# University Portal Credentials (KSU)
KSU_DOMAIN=https://schedule.buketov.edu.kz
KSU_LOGIN=your_ksu_login
KSU_PASSWORD=your_ksu_password

# Debug mode (visible browser, more logs)
DEBUG=true

# Browser settings
START_BROWSER=true
AUTO_KSU_AUTH=true

# Proxy settings (optional)
USE_PROXY=false
# HTTP_PROXY=http://proxy.example.com:8080
# PROXY_LOGIN=username
# PROXY_PASSWORD=password

# Telegram logging
TG_TOKEN=your_bot_token_here
LOG_CHANEL_ID=-100xxxxxxxxxx
LOGGER_TG_TOKEN=your_logger_bot_token_here
