# Debug mode (disables some production-only features like TG logging)
DEBUG=true

# MongoDB connection string
DB_URI=mongodb://localhost:27017/kichobot

# Telegram bot token (main bot)
TG_TOKEN=your_bot_token_here

# Telegram channel ID for logging/notifications
LOG_CHANEL_ID=-100xxxxxxxxxx

# Telegram bot token for logger bot (can be the same or different)
LOGGER_TG_TOKEN=your_logger_bot_token_here

# Main bot's numeric ID
BOT_ID=123456789

# KSU Helper API Base URL
KSU_HELPER_URL=http://localhost:5000

# Bot mode: polling or webhook
BOT_MODE=polling

# Webhook settings (only if BOT_MODE=webhook)
# WEBHOOK_DOMAIN=https://api.yourdomain.com
# WEBHOOK_PATH=/api/kichobot-bot/webhook
# WEBHOOK_PORT=5001
